{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ARForge Mode Declaration Groups",
  "description": "Schema for AUTOSAR ModeDeclarationGroup definitions.",
  "type": "object",
  "$defs": {
    "packagePath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_]+(?:\\/[A-Za-z0-9_]+)*$"
    },
    "descriptionProperty": {
      "type": "string",
      "description": "Optional human-readable documentation for this modeled object."
    },
    "modeName": {
      "type": "string",
      "description": "Mode short name inside a mode declaration group.",
      "minLength": 1,
      "examples": [
        "OFF"
      ]
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "modeDeclarationGroupCategory": {
      "type": "string",
      "enum": [
        "explicitOrder",
        "EXPLICIT_ORDER"
      ],
      "description": "YAML-facing category alias accepted by ARForge and normalized to AUTOSAR ARXML values."
    },
    "modeDeclaration": {
      "oneOf": [
        {
          "$ref": "#/$defs/modeName"
        },
        {
          "$ref": "#/$defs/modeDeclarationObject"
        }
      ]
    },
    "modeDeclarationObject": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/modeName"
        },
        "value": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      },
      "additionalProperties": false
    },
    "explicitOrderModeDeclaration": {
      "type": "object",
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/modeName"
        },
        "value": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      },
      "additionalProperties": false
    },
    "modeDeclarationGroup": {
      "type": "object",
      "description": "AUTOSAR mode declaration group definition.",
      "required": [
        "name",
        "initialMode",
        "modes"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Mode declaration group short name.",
          "minLength": 1,
          "examples": [
            "Mdg_PowerState"
          ]
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "package": {
          "$ref": "#/$defs/packagePath",
          "description": "Optional ARXML package path below the project root package."
        },
        "category": {
          "$ref": "#/$defs/modeDeclarationGroupCategory",
          "examples": [
            "explicitOrder"
          ]
        },
        "initialMode": {
          "$ref": "#/$defs/modeName"
        },
        "onTransitionValue": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "modes": {
          "type": "array",
          "description": "Ordered list of mode names declared by this group.",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/modeDeclaration"
          },
          "examples": [
            [
              {
                "name": "OFF",
                "value": 0
              },
              {
                "name": "ACC",
                "value": 1
              },
              {
                "name": "ON",
                "value": 2
              }
            ]
          ]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "category": {
                "enum": [
                  "explicitOrder",
                  "EXPLICIT_ORDER"
                ]
              }
            },
            "required": [
              "category"
            ]
          },
          "then": {
            "required": [
              "onTransitionValue"
            ],
            "properties": {
              "modes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/explicitOrderModeDeclaration"
                }
              }
            }
          }
        }
      ],
      "examples": [
        {
          "name": "Mdg_PowerState",
          "description": "Power state modes for the ECU.",
          "category": "explicitOrder",
          "initialMode": "OFF",
          "onTransitionValue": 255,
          "modes": [
            {
              "name": "OFF",
              "value": 0
            },
            {
              "name": "ACC",
              "value": 1
            },
            {
              "name": "ON",
              "value": 2
            }
          ]
        }
      ]
    }
  },
  "required": [
    "modeDeclarationGroups"
  ],
  "properties": {
    "modeDeclarationGroups": {
      "type": "array",
      "description": "List of AUTOSAR mode declaration groups.",
      "items": {
        "$ref": "#/$defs/modeDeclarationGroup"
      }
    }
  },
  "additionalProperties": false
}
