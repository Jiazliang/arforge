{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ARForge System",
  "description": "Schema for the system composition that instantiates SWCs and connects their ports.",
  "type": "object",
  "$defs": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "packagePath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_]+(?:\\/[A-Za-z0-9_]+)*$"
    },
    "descriptionProperty": {
      "type": "string",
      "description": "Optional human-readable documentation for this modeled object."
    },
    "endpoint": {
      "type": "string",
      "description": "Component instance and port reference in the form InstanceName.PortName.",
      "pattern": "^[A-Za-z0-9_]+\\.[A-Za-z0-9_]+$",
      "examples": [
        "SpeedSensor_1.Pp_VehicleSpeed"
      ]
    },
    "componentPrototype": {
      "type": "object",
      "description": "Component instance declared in the system composition.",
      "required": [
        "name",
        "typeRef"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name",
          "description": "Instance name used by connector endpoints.",
          "examples": [
            "SpeedSensor_1"
          ]
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "typeRef": {
          "$ref": "#/$defs/name",
          "description": "Atomic SWC type or reusable subcomposition type instantiated by this component prototype.",
          "examples": [
            "SpeedSensor"
          ]
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "name": "SpeedSensor_1",
          "typeRef": "SpeedSensor"
        }
      ]
    },
    "connector": {
      "type": "object",
      "description": "Port-level assembly connector between two component instance ports.",
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "$ref": "#/$defs/endpoint",
          "description": "Source endpoint in the form InstanceName.PortName."
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "to": {
          "$ref": "#/$defs/endpoint",
          "description": "Target endpoint in the form InstanceName.PortName."
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "from": "SpeedSensor_1.Pp_VehicleSpeed",
          "to": "SpeedConsumer_1.Rp_VehicleSpeed"
        }
      ]
    }
  },
  "required": [
    "system"
  ],
  "properties": {
    "system": {
      "type": "object",
      "description": "Single AUTOSAR system definition.",
      "required": [
        "name",
        "composition"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name",
          "description": "System short name.",
          "examples": [
            "DemoSystem"
          ]
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "package": {
          "$ref": "#/$defs/packagePath",
          "description": "Optional ARXML package path below the project root package."
        },
        "composition": {
          "type": "object",
          "description": "Top-level composition containing component instances and assembly connectors. Component type references may target atomic SWCs or reusable subcomposition types.",
          "required": [
            "name",
            "components",
            "connectors"
          ],
          "properties": {
            "name": {
              "$ref": "#/$defs/name",
              "description": "Composition short name.",
              "examples": [
                "Composition_DemoSystem"
              ]
            },
            "description": {
              "$ref": "#/$defs/descriptionProperty"
            },
            "components": {
              "type": "array",
              "description": "Component instances inside the composition.",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/componentPrototype"
              }
            },
            "connectors": {
              "type": "array",
              "description": "Assembly connectors between component instances.",
              "items": {
                "$ref": "#/$defs/connector"
              }
            }
          },
          "additionalProperties": false,
          "examples": [
            {
              "name": "Composition_DemoSystem",
              "components": [
                {
                  "name": "SpeedSensor_1",
                  "typeRef": "SpeedSensor"
                }
              ],
              "connectors": [
                {
                  "from": "SpeedSensor_1.Pp_VehicleSpeed",
                  "to": "SpeedConsumer_1.Rp_VehicleSpeed"
                }
              ]
            }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "system": {
        "name": "DemoSystem",
        "composition": {
          "name": "Composition_DemoSystem",
          "components": [
            {
              "name": "SpeedSensor_1",
              "typeRef": "SpeedSensor"
            },
            {
              "name": "SpeedConsumer_1",
              "typeRef": "SpeedConsumer"
            }
          ],
          "connectors": [
            {
              "from": "SpeedSensor_1.Pp_VehicleSpeed",
              "to": "SpeedConsumer_1.Rp_VehicleSpeed"
            }
          ]
        }
      }
    }
  ]
}
