{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "arforge: init project",
      "type": "shell",
      "command": "${workspaceFolder}${/}.venv${/}bin${/}python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "linux": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "args": [
        "-m",
        "arforge.cli",
        "init",
        "demo-project"
      ],
      "problemMatcher": []
    },
    {
      "label": "arforge: validate project (core)",
      "type": "shell",
      "command": "${workspaceFolder}${/}.venv${/}bin${/}python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "linux": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "args": [
        "-m",
        "arforge.cli",
        "validate",
        "${config:arforge.projectFile}",
        "-vv"
      ],
      "problemMatcher": []
    },
    {
      "label": "arforge: validate project (profile)",
      "type": "shell",
      "command": "${workspaceFolder}${/}.venv${/}bin${/}python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "linux": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "args": [
        "-m",
        "arforge.cli",
        "validate",
        "${config:arforge.projectFile}",
        "--profile",
        "${config:arforge.validationProfile}",
        "-vv"
      ],
      "problemMatcher": []
    },
    {
      "label": "arforge: export project (monolithic)",
      "type": "shell",
      "command": "${workspaceFolder}${/}.venv${/}bin${/}python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "linux": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "args": [
        "-m",
        "arforge.cli",
        "export",
        "${config:arforge.projectFile}",
        "--out",
        "${config:arforge.outputDir}/arxml/project.arxml",
        "-vv"
      ],
      "problemMatcher": []
    },
    {
      "label": "arforge: export project (split by swc)",
      "type": "shell",
      "command": "${workspaceFolder}${/}.venv${/}bin${/}python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "linux": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "args": [
        "-m",
        "arforge.cli",
        "export",
        "${config:arforge.projectFile}",
        "--out",
        "${config:arforge.outputDir}/arxml",
        "--split-by-swc",
        "-vv"
      ],
      "problemMatcher": []
    },
    {
      "label": "arforge: pytest",
      "type": "shell",
      "command": "${workspaceFolder}${/}.venv${/}bin${/}python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "linux": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "args": ["-m", "pytest", "-q"],
      "problemMatcher": []
    },
    {
      "label": "arforge: generate Plantuml",
      "type": "shell",
      "command": "${workspaceFolder}${/}.venv${/}bin${/}python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "linux": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "args": [
        "-m",
        "arforge.cli",
        "generate",
        "diagram",
        "${config:arforge.projectFile}",
        "--out",
        "${config:arforge.outputDir}/diagrams"
      ],
      "problemMatcher": []
    },
    {
      "label": "arforge: generate C-code",
      "type": "shell",
      "command": "${workspaceFolder}${/}.venv${/}bin${/}python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "linux": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "args": [
        "-m",
        "arforge.cli",
        "generate",
        "code",
        "${config:arforge.projectFile}",
        "--lang",
        "c",
        "--out",
        "${config:arforge.outputDir}/code"
      ],
      "problemMatcher": []
    },
    {
      "label": "arforge: generate report",
      "type": "shell",
      "command": "${workspaceFolder}${/}.venv${/}bin${/}python",
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "linux": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python"
      },
      "args": [
        "-m",
        "arforge.cli",
        "report",
        "${config:arforge.projectFile}",
        "--out",
        "${config:arforge.outputDir}/docs/Report.md"
      ],
      "problemMatcher": []
    }
  ]
}
