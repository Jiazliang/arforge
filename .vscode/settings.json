{
  "yaml.validate": true,
  "yaml.hover": true,
  "yaml.completion": true,

  "arforge.projectFile": "examples/minimal/autosar.project.yaml",
  "arforge.validationProfile": "examples/features/validation_profiles/naming.yaml",
  "arforge.outputDir": "build",

  "yaml.schemas": {
    "./schemas/aggregator.schema.json": [
      "**/autosar.project.yaml",
      "**/*.project.yaml"
    ],

    "./schemas/validation_profile.schema.json": [
      "**/validation_profiles/*.yaml",
      "**/profile.yaml"
    ],

    "./schemas/interface.schema.json": [
      "**/interfaces/*.yaml"
    ],

    "./schemas/swc.schema.json": [
      "**/swcs/*.yaml"
    ],

    "./schemas/system.schema.json": [
      "**/system.yaml"
    ],

    "./schemas/mode_declaration_groups.schema.json": [
      "**/modes/*.yaml"
    ],

    "./schemas/subcomposition.schema.json": [
      "**/subcompositions/*.yaml"
    ],

    "./schemas/base_types.schema.json": [
      "**/base_types.yaml",
      "**/platform/base_types.yaml"
    ],

    "./schemas/implementation_types.schema.json": [
      "**/implementation_types.yaml"
    ],

    "./schemas/application_types.schema.json": [
      "**/application_types.yaml"
    ],

    "./schemas/units.schema.json": [
      "**/units.yaml"
    ],

    "./schemas/compu_methods.schema.json": [
      "**/compu_methods.yaml"
    ]
  }
}
