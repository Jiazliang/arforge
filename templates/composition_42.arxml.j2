<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_4-2-2.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>{{ root_pkg }}</SHORT-NAME>
      <AR-PACKAGES>

        <AR-PACKAGE>
          <SHORT-NAME>Components</SHORT-NAME>
          <ELEMENTS>
            <COMPOSITION-SW-COMPONENT-TYPE>
              <SHORT-NAME>{{ composition.name }}</SHORT-NAME>
              {% if composition.ports %}
              <PORTS>
                {% for p in composition.ports %}
                  {% if p.direction == "provides" %}
                <P-PORT-PROTOTYPE>
                  <SHORT-NAME>{{ p.name }}</SHORT-NAME>
                  {% if p.interfaceType == "senderReceiver" %}
                  <PROVIDED-INTERFACE-TREF DEST="SENDER-RECEIVER-INTERFACE">/{{ root_pkg }}/Interfaces/{{ p.interfaceRef }}</PROVIDED-INTERFACE-TREF>
                  {% elif p.interfaceType == "clientServer" %}
                  <PROVIDED-INTERFACE-TREF DEST="CLIENT-SERVER-INTERFACE">/{{ root_pkg }}/Interfaces/{{ p.interfaceRef }}</PROVIDED-INTERFACE-TREF>
                  {% elif p.interfaceType == "modeSwitch" %}
                  <PROVIDED-INTERFACE-TREF DEST="MODE-SWITCH-INTERFACE">/{{ root_pkg }}/Interfaces/{{ p.interfaceRef }}</PROVIDED-INTERFACE-TREF>
                  {% endif %}
                </P-PORT-PROTOTYPE>
                  {% else %}
                <R-PORT-PROTOTYPE>
                  <SHORT-NAME>{{ p.name }}</SHORT-NAME>
                  {% if p.interfaceType == "senderReceiver" %}
                  <REQUIRED-INTERFACE-TREF DEST="SENDER-RECEIVER-INTERFACE">/{{ root_pkg }}/Interfaces/{{ p.interfaceRef }}</REQUIRED-INTERFACE-TREF>
                  {% elif p.interfaceType == "clientServer" %}
                  <REQUIRED-INTERFACE-TREF DEST="CLIENT-SERVER-INTERFACE">/{{ root_pkg }}/Interfaces/{{ p.interfaceRef }}</REQUIRED-INTERFACE-TREF>
                  {% elif p.interfaceType == "modeSwitch" %}
                  <REQUIRED-INTERFACE-TREF DEST="MODE-SWITCH-INTERFACE">/{{ root_pkg }}/Interfaces/{{ p.interfaceRef }}</REQUIRED-INTERFACE-TREF>
                  {% endif %}
                </R-PORT-PROTOTYPE>
                  {% endif %}
                {% endfor %}
              </PORTS>
              {% endif %}
              <COMPONENTS>
                {% for c in composition.components %}
                <SW-COMPONENT-PROTOTYPE>
                  <SHORT-NAME>{{ c.name }}</SHORT-NAME>
                  <TYPE-TREF DEST="{{ component_type_dests[c.typeRef] }}">{{ component_type_refs[c.typeRef] }}</TYPE-TREF>
                </SW-COMPONENT-PROTOTYPE>
                {% endfor %}
              </COMPONENTS>
              <CONNECTORS>
                {% for c in composition.connections %}
                <ASSEMBLY-SW-CONNECTOR>
                  <SHORT-NAME>{{ c.short_name }}</SHORT-NAME>
                  <PROVIDER-IREF>
                    <CONTEXT-COMPONENT-REF DEST="SW-COMPONENT-PROTOTYPE">/{{ root_pkg }}/Components/{{ composition.name }}/{{ c.from_instance }}</CONTEXT-COMPONENT-REF>
                    <TARGET-P-PORT-REF DEST="P-PORT-PROTOTYPE">/{{ root_pkg }}/Components/{{ composition.name }}/{{ c.from_instance }}/{{ c.from_port }}</TARGET-P-PORT-REF>
                  </PROVIDER-IREF>
                  <REQUESTER-IREF>
                    <CONTEXT-COMPONENT-REF DEST="SW-COMPONENT-PROTOTYPE">/{{ root_pkg }}/Components/{{ composition.name }}/{{ c.to_instance }}</CONTEXT-COMPONENT-REF>
                    <TARGET-R-PORT-REF DEST="R-PORT-PROTOTYPE">/{{ root_pkg }}/Components/{{ composition.name }}/{{ c.to_instance }}/{{ c.to_port }}</TARGET-R-PORT-REF>
                  </REQUESTER-IREF>
                </ASSEMBLY-SW-CONNECTOR>
                {% endfor %}
                {% for c in composition.delegation_connectors %}
                <DELEGATION-SW-CONNECTOR>
                  <SHORT-NAME>{{ c.short_name }}</SHORT-NAME>
                  {% if c.outer_direction == "provides" %}
                  <INNER-PORT-IREF>
                    <CONTEXT-COMPONENT-REF DEST="SW-COMPONENT-PROTOTYPE">/{{ root_pkg }}/Components/{{ composition.name }}/{{ c.inner_instance }}</CONTEXT-COMPONENT-REF>
                    <TARGET-P-PORT-REF DEST="P-PORT-PROTOTYPE">/{{ root_pkg }}/Components/{{ composition.name }}/{{ c.inner_instance }}/{{ c.inner_port }}</TARGET-P-PORT-REF>
                  </INNER-PORT-IREF>
                  <OUTER-PORT-REF DEST="P-PORT-PROTOTYPE">/{{ root_pkg }}/Components/{{ composition.name }}/{{ c.outer_port }}</OUTER-PORT-REF>
                  {% else %}
                  <INNER-PORT-IREF>
                    <CONTEXT-COMPONENT-REF DEST="SW-COMPONENT-PROTOTYPE">/{{ root_pkg }}/Components/{{ composition.name }}/{{ c.inner_instance }}</CONTEXT-COMPONENT-REF>
                    <TARGET-R-PORT-REF DEST="R-PORT-PROTOTYPE">/{{ root_pkg }}/Components/{{ composition.name }}/{{ c.inner_instance }}/{{ c.inner_port }}</TARGET-R-PORT-REF>
                  </INNER-PORT-IREF>
                  <OUTER-PORT-REF DEST="R-PORT-PROTOTYPE">/{{ root_pkg }}/Components/{{ composition.name }}/{{ c.outer_port }}</OUTER-PORT-REF>
                  {% endif %}
                </DELEGATION-SW-CONNECTOR>
                {% endfor %}
              </CONNECTORS>
            </COMPOSITION-SW-COMPONENT-TYPE>
          </ELEMENTS>
        </AR-PACKAGE>

      </AR-PACKAGES>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>
